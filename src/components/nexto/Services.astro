---
/**
 * 넥스투 커스텀 "핵심 사업 영역" 섹션 — 프리미엄 카드 그리드.
 * 다크 Hero 다음의 밝은 섹션. 호버 리프트 + 액센트 바 + 화살표 링크.
 */
import { Icon } from 'astro-icon/components';

const items = [
  {
    title: '산업 자동화',
    description: '생산 설비의 자동 제어·검사 자동화로 생산성과 품질을 동시에 끌어올립니다.',
    icon: 'tabler:cpu',
    href: '/services/industrial-automation',
  },
  {
    title: 'MES',
    description: '현장 데이터를 실시간 수집·관리해 생산 흐름을 한눈에 보이게 만듭니다.',
    icon: 'tabler:layout-dashboard',
    href: '/services/mes',
  },
  {
    title: '스마트 팩토리',
    description: '설비·공정·데이터를 연결한 지능형 공장 구축을 단계적으로 지원합니다.',
    icon: 'tabler:building-factory-2',
    href: '/services/smart-factory',
  },
  {
    title: 'AI 솔루션',
    description: 'AI 기반 검사·예지보전·최적화로 제조 경쟁력을 강화합니다.',
    icon: 'tabler:sparkles',
    href: '/services/ai',
  },
];
---

<section class="relative bg-white dark:bg-[#0b2c49]">
  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-20 md:py-28">
    <!-- 섹션 헤더 -->
    <div class="max-w-2xl">
      <p class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-primary">
        <span class="h-px w-8 bg-primary"></span>
        Core Business
      </p>
      <h2 class="mt-3 font-heading text-3xl font-extrabold tracking-tight text-heading break-keep sm:text-4xl lg:text-5xl">
        제조 혁신에 필요한 기술을<br class="hidden sm:block" /> 한 곳에서
      </h2>
      <p class="mt-4 text-lg text-muted break-keep">
        자동화부터 AI까지 — 진단·구축·운영을 아우르는 넥스투의 핵심 역량.
      </p>
    </div>

    <!-- 카드 그리드 -->
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        items.map((it) => (
          <a
            href={it.href}
            class="group relative flex flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white p-7 transition duration-300 hover:-translate-y-1.5 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/10 dark:border-white/10 dark:bg-white/5 dark:hover:border-primary/50"
          >
            {/* 상단 액센트 바 (호버 시 확장) */}
            <span class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-gradient-to-r from-primary to-sky-400 transition-transform duration-300 group-hover:scale-x-100" />

            <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-primary/10 text-primary transition group-hover:bg-primary group-hover:text-white">
              <Icon name={it.icon} class="h-7 w-7" />
            </div>

            <h3 class="mt-5 text-xl font-bold text-heading">{it.title}</h3>
            <p class="mt-2 flex-1 text-[15px] leading-relaxed text-muted break-keep">{it.description}</p>

            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-primary">
              자세히 보기
              <Icon name="tabler:arrow-right" class="h-4 w-4 transition group-hover:translate-x-1" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
