---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Button from '~/components/ui/Button.astro';

const metadata = {
  title: '문의',
};

// 폼 입력 공통 스타일 (AstroWind Form.astro와 동일 톤)
const inputClass =
  'py-3 px-4 block w-full text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900';

// Web3Forms access key — 리포에 하드코딩하지 않고 빌드 환경변수로 주입한다.
// (Cloudflare Pages > Settings > Environment variables 에 PUBLIC_WEB3FORMS_KEY 등록)
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
---

<Layout metadata={metadata}>
  <!-- HeroText ******************* -->
  <HeroText tagline="Contact" title="문의하기" subtitle="자동화·스마트팩토리·AI 도입, 무엇이든 편하게 문의해 주세요." />

  <!-- 온라인 문의 폼 (Web3Forms) ******************* -->
  <!--
    Web3Forms 연동 (호스팅 무관, Cloudflare Pages 배포용):
    - 무료 access key를 https://web3forms.com 에서 이메일로 발급받는다(수신 이메일 = 그 이메일).
    - 발급 키를 Cloudflare Pages > Settings > Environment variables 의 PUBLIC_WEB3FORMS_KEY 에 등록.
    - 제출 시 api.web3forms.com 으로 POST → 등록 이메일로 문의 내용 전달.
    - botcheck(허니팟)로 스팸 봇을 거른다.
  -->
  <section class="px-4 py-12 sm:px-6 mx-auto max-w-7xl">
    <div
      class="flex flex-col max-w-xl mx-auto rounded-lg backdrop-blur border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 shadow p-4 sm:p-6 lg:p-8 w-full"
    >
      <div class="mb-6 text-center">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">온라인 문의</h2>
        <p class="mt-2 text-muted">
          아래 양식을 작성해 주시면 담당자가 영업일 기준 24시간 이내에 답변드립니다.
        </p>
      </div>

      <form action="https://api.web3forms.com/submit" method="POST">
        <!-- Web3Forms 인증 키 (빌드 시 환경변수에서 주입) -->
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <!-- 수신 메일 제목/발신 이름 -->
        <input type="hidden" name="subject" value="[넥스투 홈페이지] 새 문의가 접수되었습니다" />
        <input type="hidden" name="from_name" value="넥스투 웹사이트" />
        <!-- 스팸 봇 트랩 (사용자에게는 숨김) -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="mb-6">
          <label for="name" class="block text-sm font-medium">이름 *</label>
          <input type="text" name="name" id="name" required class={inputClass} />
        </div>

        <div class="mb-6">
          <label for="company" class="block text-sm font-medium">회사명</label>
          <input type="text" name="company" id="company" class={inputClass} />
        </div>

        <div class="mb-6 grid gap-6 sm:grid-cols-2">
          <div>
            <label for="email" class="block text-sm font-medium">이메일 *</label>
            <input type="email" name="email" id="email" required class={inputClass} />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium">연락처</label>
            <input type="tel" name="phone" id="phone" class={inputClass} />
          </div>
        </div>

        <div class="mb-6">
          <label for="type" class="block text-sm font-medium">문의 유형</label>
          <select name="type" id="type" class={inputClass}>
            <option value="산업 자동화">산업 자동화</option>
            <option value="MES">MES</option>
            <option value="스마트 팩토리">스마트 팩토리</option>
            <option value="AI 솔루션">AI 솔루션</option>
            <option value="기타">기타</option>
          </select>
        </div>

        <div class="mb-6">
          <label for="message" class="block text-sm font-medium">문의 내용 *</label>
          <textarea name="message" id="message" rows={4} required class={inputClass}></textarea>
        </div>

        <div class="mt-3 flex items-start">
          <div class="flex mt-0.5">
            <input
              id="disclaimer"
              name="disclaimer"
              type="checkbox"
              required
              class="cursor-pointer mt-1 py-3 px-4 block text-md rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900"
            />
          </div>
          <div class="ml-3">
            <label for="disclaimer" class="cursor-pointer select-none text-sm text-gray-600 dark:text-gray-400">
              개인정보 수집·이용에 동의합니다. (문의 접수 및 답변 목적으로만 사용)
            </label>
          </div>
        </div>

        <div class="mt-10 grid">
          <Button variant="primary" type="submit">문의 보내기</Button>
        </div>
      </form>
    </div>
  </section>

  <!-- 연락처 정보 ************** -->
  <Features2
    title="연락처"
    subtitle="언제든 편하게 연락 주세요."
    items={[
      {
        title: '전화',
        description: 'Tel. 02-404-3350 / Fax. 02-404-3351<br />Mobile. 010-7114-4308',
        icon: 'tabler:headset',
      },
      {
        title: '이메일',
        description: 'admin@nexto.co.kr',
        icon: 'tabler:mail',
      },
      {
        title: '오시는 길',
        description: '서울특별시 송파구 송파대로28길 12, 607호 (가락동, 밀리아나 1차)',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
